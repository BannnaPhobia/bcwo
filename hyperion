local ThemeChoice = "Default"

-- Theme must be set before Rayfield loads so we store it and reload if changed
local function loadScript(theme)
    local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local LocalPlayer = Players.LocalPlayer
    local currentIndex = 1
    local autoFarming = false
    local selectedOres = {}
    local fullbrightEnabled = false
    local originalBrightness, originalAmbient, originalOutdoorAmbient

    local oreList = {
        "Lead", "Iron", "Crystal", "Gold", "Diamond",
        "Cobalt", "Oureclasium", "Viridis", "Tungsten",
        "Titanium", "Mithril", "Adamantine", "Titanstone",
        "Gemstone of Purity", "Gemstone of Hatred", "Astral Silver",
        "Irradium", "Uranium", "Plutonium", "Purite", "Hatrite",
        "Aurium", "Duranite", "Hevenite", "Hellite", "Lanite",
        "Moonstone", "Forbidden Crystal"
    }

    local pickaxeNames = {
        "Iron Pickaxe", "Gold Pickaxe", "Diamond Pickaxe",
        "Cobalt Pickaxe", "Darksteel Pickaxe", "Viridis Pickaxe",
        "Pickaxe of Balance"
    }

    local oreToggles = {}

    local function findPickaxe()
        local char = LocalPlayer.Character
        local backpack = LocalPlayer.Backpack
        for _, tool in ipairs(backpack:GetChildren()) do
            for _, name in ipairs(pickaxeNames) do
                if tool.Name == name then return tool end
            end
        end
        if char then
            for _, tool in ipairs(char:GetChildren()) do
                if tool:IsA("Tool") then
                    for _, name in ipairs(pickaxeNames) do
                        if tool.Name == name then return tool end
                    end
                end
            end
        end
        return nil
    end

    local function equipPickaxe()
        local tool = findPickaxe()
        if not tool then return nil end
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum then hum:EquipTool(tool) end
        task.wait(0.5)
        if char then
            for _, t in ipairs(char:GetChildren()) do
                if t:IsA("Tool") then return t end
            end
        end
        return tool
    end

    local miningActive = false
    local function startMining(tool)
        miningActive = true
        task.spawn(function()
            local rf = tool:FindFirstChild("RemoteFunction")
            local speed = tool:FindFirstChild("Speed") and tool.Speed.Value or 1
            if not rf then
                local re = tool:FindFirstChild("PickaxeControl")
                if re then
                    while miningActive do
                        re:FireServer("mine")
                        task.wait(speed)
                    end
                end
                return
            end
            while miningActive do
                pcall(function() rf:InvokeServer("mine") end)
                task.wait(speed)
            end
        end)
    end

    local function stopMining()
        miningActive = false
    end

    local function teleportToSide(part)
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        local orePos = part.Position
        local sides = {
            Vector3.new(4, 0, 0), Vector3.new(-4, 0, 0),
            Vector3.new(0, 0, 4), Vector3.new(0, 0, -4),
        }
        local bestPos = orePos + sides[1] + Vector3.new(0, 3, 0)
        for _, side in ipairs(sides) do
            local candidate = orePos + side
            local ray = Ray.new(candidate + Vector3.new(0, 5, 0), Vector3.new(0, -10, 0))
            local hit = workspace:FindPartOnRayWithIgnoreList(ray, {char})
            if hit then
                bestPos = candidate + Vector3.new(0, 3, 0)
                break
            end
        end
        char.HumanoidRootPart.CFrame = CFrame.new(bestPos, orePos)
    end

    local function setFullbright(enabled)
        local lighting = game:GetService("Lighting")
        if enabled then
            originalBrightness = lighting.Brightness
            originalAmbient = lighting.Ambient
            originalOutdoorAmbient = lighting.OutdoorAmbient
            lighting.Brightness = 2
            lighting.Ambient = Color3.fromRGB(255, 255, 255)
            lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
            lighting.ClockTime = 14
            lighting.FogEnd = 100000
        else
            if originalBrightness then lighting.Brightness = originalBrightness end
            if originalAmbient then lighting.Ambient = originalAmbient end
            if originalOutdoorAmbient then lighting.OutdoorAmbient = originalOutdoorAmbient end
        end
    end

    local function findOres()
        local ores = {}
        local activeOres = {}
        for name, active in pairs(selectedOres) do
            if active then activeOres[name] = true end
        end
        if next(activeOres) == nil then return ores end
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and activeOres[obj.Name] then
                local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                if part then
                    local pos = part.Position
                    if pos.X > -3000 and pos.Y < 500 then
                        table.insert(ores, {model = obj, part = part, name = obj.Name})
                    end
                end
            end
        end
        return ores
    end

    local function waitForOreMined(oreModel, timeoutSeconds)
        local mined = false
        local connection
        connection = oreModel.AncestryChanged:Connect(function(_, parent)
            if parent == nil then mined = true end
        end)
        local elapsed = 0
        while not mined and elapsed < timeoutSeconds do
            if not oreModel or not oreModel.Parent then mined = true break end
            task.wait(0.1)
            elapsed = elapsed + 0.1
        end
        pcall(function() connection:Disconnect() end)
        return mined
    end

    -- ===================== RAYFIELD UI =====================
    local Window = Rayfield:CreateWindow({
        Name = "BCO Ore Miner",
        LoadingTitle = "BCO Ore Miner",
        LoadingSubtitle = "by phobia",
        Theme = theme,
        DisableRayfieldPrompts = false,
        DisableBuildWarnings = false,
    })

    local MainTab     = Window:CreateTab("🏠 Main", 4483362458)
    local MineTab     = Window:CreateTab("⛏ Mine & Ores", 4483362458)
    local SettingsTab = Window:CreateTab("⚙ Settings", 4483362458)

    -- ====== MAIN TAB ======
    MainTab:CreateSection("Welcome")
    MainTab:CreateLabel("Welcome to BCO Ore Miner by phobia.")
    MainTab:CreateLabel("More features coming soon.")

    -- ====== MINE & ORES TAB ======
    MineTab:CreateSection("Status")
    local statusLabel  = MineTab:CreateLabel("Status: Ready — select ores below")
    local pickaxeLabel = MineTab:CreateLabel("Pickaxe: Searching...")

    local function setStatus(msg) statusLabel:Set("Status: " .. msg) end
    local function setPickaxeStatus(msg) pickaxeLabel:Set("Pickaxe: " .. msg) end

    MineTab:CreateSection("Actions")

    MineTab:CreateButton({
        Name = "Teleport to Nearest Ore",
        Callback = function()
            local ores = findOres()
            if #ores == 0 then
                Rayfield:Notify({ Title = "No Ores", Content = "No selected ores found!", Duration = 3 })
                return
            end
            local char = LocalPlayer.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            local pos = char.HumanoidRootPart.Position
            local nearest, dist, nName = nil, math.huge, ""
            for _, ore in ipairs(ores) do
                local d = (ore.part.Position - pos).Magnitude
                if d < dist then nearest = ore dist = d nName = ore.name end
            end
            if nearest then
                teleportToSide(nearest.part)
                local t = equipPickaxe()
                if t then setPickaxeStatus(t.Name .. " equipped") end
                setStatus(nName .. " (" .. math.floor(dist) .. " studs)")
                Rayfield:Notify({ Title = "Teleported!", Content = nName .. " — " .. math.floor(dist) .. " studs away", Duration = 2 })
            end
        end,
    })

    MineTab:CreateButton({
        Name = "Teleport to Next Ore",
        Callback = function()
            local ores = findOres()
            if #ores == 0 then
                Rayfield:Notify({ Title = "No Ores", Content = "No selected ores found!", Duration = 3 })
                return
            end
            if currentIndex > #ores then currentIndex = 1 end
            local ore = ores[currentIndex]
            teleportToSide(ore.part)
            local t = equipPickaxe()
            if t then setPickaxeStatus(t.Name .. " equipped") end
            setStatus(ore.name .. " " .. currentIndex .. "/" .. #ores)
            Rayfield:Notify({ Title = "Teleported!", Content = ore.name .. " (" .. currentIndex .. "/" .. #ores .. ")", Duration = 2 })
            currentIndex = currentIndex + 1
        end,
    })

    MineTab:CreateButton({
        Name = "Count Selected Ores",
        Callback = function()
            local ores = findOres()
            Rayfield:Notify({ Title = "Ore Count", Content = "Found " .. #ores .. " ore(s) in the caverns.", Duration = 3 })
            setStatus("Found " .. #ores .. " ore(s)")
        end,
    })

    MineTab:CreateButton({
        Name = "Reset Ore Index",
        Callback = function()
            currentIndex = 1
            setStatus("Index reset to 1")
            Rayfield:Notify({ Title = "Reset", Content = "Ore index reset to 1.", Duration = 2 })
        end,
    })

    MineTab:CreateSection("Auto Farm")

    MineTab:CreateToggle({
        Name = "Auto Farm",
        CurrentValue = false,
        Flag = "AutoFarm",
        Callback = function(val)
            autoFarming = val
            if val then
                setStatus("Auto farming...")
                Rayfield:Notify({ Title = "Auto Farm ON", Content = "Farming selected ores.", Duration = 3 })
                task.spawn(function()
                    while autoFarming do
                        local ores = findOres()
                        if #ores == 0 then
                            stopMining()
                            setStatus("No ores found — waiting...")
                            task.wait(2)
                        else
                            if currentIndex > #ores then currentIndex = 1 end
                            local ore = ores[currentIndex]
                            currentIndex = currentIndex + 1
                            teleportToSide(ore.part)
                            setStatus("Mining " .. ore.name .. " " .. (currentIndex-1) .. "/" .. #ores)
                            local tool = equipPickaxe()
                            if not tool then
                                setPickaxeStatus("No pickaxe found!")
                                task.wait(1)
                                continue
                            end
                            setPickaxeStatus(tool.Name .. " equipped")
                            task.wait(0.3)
                            startMining(tool)
                            local mined = waitForOreMined(ore.model, 60)
                            stopMining()
                            if mined then
                                setStatus("Mined! Moving to next...")
                            else
                                setStatus("Timeout — skipping ore...")
                            end
                            task.wait(0.2)
                        end
                    end
                    stopMining()
                end)
            else
                stopMining()
                setStatus("Auto farm stopped")
                Rayfield:Notify({ Title = "Auto Farm OFF", Content = "Stopped.", Duration = 2 })
            end
        end,
    })

    MineTab:CreateSection("Visual")

    MineTab:CreateToggle({
        Name = "Fullbright",
        CurrentValue = fullbrightEnabled,
        Flag = "Fullbright",
        Callback = function(val)
            fullbrightEnabled = val
            setFullbright(val)
            Rayfield:Notify({
                Title = val and "Fullbright ON" or "Fullbright OFF",
                Content = val and "Lighting maximised." or "Lighting restored.",
                Duration = 2,
            })
        end,
    })

    MineTab:CreateSection("Ore Selection")

    MineTab:CreateButton({
        Name = "Select All Ores",
        Callback = function()
            for _, oreName in ipairs(oreList) do
                selectedOres[oreName] = true
                if oreToggles[oreName] then oreToggles[oreName]:Set(true) end
            end
            Rayfield:Notify({ Title = "Selected All", Content = #oreList .. " ore types selected.", Duration = 2 })
            setStatus(#oreList .. " ore types selected")
        end,
    })

    MineTab:CreateButton({
        Name = "Deselect All Ores",
        Callback = function()
            for _, oreName in ipairs(oreList) do
                selectedOres[oreName] = false
                if oreToggles[oreName] then oreToggles[oreName]:Set(false) end
            end
            Rayfield:Notify({ Title = "Deselected All", Content = "All ores deselected.", Duration = 2 })
            setStatus("Ready — select ores to begin")
        end,
    })

    for _, oreName in ipairs(oreList) do
        local toggle = MineTab:CreateToggle({
            Name = oreName,
            CurrentValue = selectedOres[oreName] or false,
            Flag = "Ore_" .. oreName,
            Callback = function(val)
                selectedOres[oreName] = val
                local count = 0
                for _, v in pairs(selectedOres) do if v then count = count + 1 end end
                setStatus(count .. " ore type(s) selected")
            end,
        })
        oreToggles[oreName] = toggle
    end

    -- ====== SETTINGS TAB ======
    SettingsTab:CreateSection("Theme")
    SettingsTab:CreateLabel("Current theme: " .. theme)

    SettingsTab:CreateDropdown({
        Name = "Select Theme",
        Options = {"Default", "Amethyst", "Bloom", "Ocean", "Solar"},
        CurrentOption = {theme},
        Flag = "ThemeDropdown",
        Callback = function(option)
            local chosen = option[1] or option
            if chosen ~= theme then
                ThemeChoice = chosen
                -- Destroy old UI and reload with new theme
                Rayfield:Destroy()
                task.wait(0.3)
                loadScript(chosen)
            end
        end,
    })

    SettingsTab:CreateSection("Credits")
    SettingsTab:CreateLabel("BCO Ore Miner — by phobia")
    SettingsTab:CreateLabel("Version 1.0")

    -- Init
    local t = findPickaxe()
    if t then setPickaxeStatus(t.Name .. " detected") else setPickaxeStatus("No pickaxe in backpack") end

    Rayfield:Notify({
        Title = "BCO Ore Miner",
        Content = "Theme: " .. theme .. " — by phobia",
        Duration = 4,
        Image = 4483362458,
    })
end

loadScript(ThemeChoice)
